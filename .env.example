# Copy to .env on the Pi (or dev machine) and fill in values.
# See README for OAuth setup notes.

FLASK_ENV=development
# Host binding for Pi: typically 127.0.0.1 behind a local browser, or 0.0.0.0 for LAN debugging
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=8765

# Spotify app credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# After completing the authorization code flow once, paste the refresh token here.
# The backend will exchange it for short-lived access tokens.
# TODO: On the Pi, consider storing tokens in a small sqlite/db file instead of plain .env
SPOTIFY_REFRESH_TOKEN=

# Optional: skip token refresh during prototyping by pasting a user access token
# (expires in ~1 hour). Takes precedence over refresh flow if set.
SPOTIFY_ACCESS_TOKEN=

# Must match a redirect URI registered on your Spotify app (only needed for one-time OAuth helpers)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/callback

# If true (or if no usable Spotify credentials are configured), API returns mock playback data
# so the kiosk UI can be exercised without hitting Spotify.
SPOTIFY_USE_MOCK=false
